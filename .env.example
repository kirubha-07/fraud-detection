# Copy to .env and fill in values as needed

# Frontend: Next.js API base URL (also set in frontend/.env.local for local dev)
NEXT_PUBLIC_API_URL=http://localhost:8000

# Optional: Kaggle credentials for downloading the raw dataset
# (only needed if re-downloading data/raw/paysim.csv via the Kaggle API)
KAGGLE_USERNAME=your_kaggle_username
KAGGLE_KEY=your_kaggle_api_key
